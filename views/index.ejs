<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edge Cases | SME Assist AI</title>
  <meta name="description"
    content="SME Assist AI helps small businesses respond to customer enquiries faster with a simple AI assistant." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Merriweather:wght@700&family=Source+Code+Pro:wght@600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>

<body>
  <%- include('partials/header') %>

    <main>
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-content centered-hero">
            <p class="eyebrow"><i class="fa-solid fa-robot"></i> AI customer support for SMEs</p>
            <h1>Your website, answering for itself.</h1>
            <p class="hero-text">SME Assist AI provides a lightweight chatbot that answers common customer enquiries
              instantly, so your team can focus on running the business.</p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="/demo">Get started</a>
              <a class="btn btn-secondary" href="#how-it-works">Live demo</a>
            </div>
          </div>

          <div class="hero-card hero-mockup">
            <div class="live-chat-preview">
              <div class="live-chat-header">
                <div>
                  <div class="preview-label">Live preview</div>
                  <strong>SME Assist AI</strong>
                </div>
                <span class="online-pill">
                  <span class="online-dot"></span>
                  Online
                </span>
              </div>

              <div class="live-chat-body">
                <div class="chat-loop-message customer msg-1">
                  Are you open today?
                </div>

                <div class="chat-loop-message bot msg-2">
                  Yes — we're open 10 AM to 9 PM today. Need help with a booking?
                </div>

                <div class="chat-loop-message customer msg-3">
                  How much is your chatbot flow?
                </div>

                <div class="chat-loop-message bot msg-4">
                  Botpress starts from $5, Telegram from $8, and custom SME flows from $10.
                </div>

                <div class="chat-loop-message customer msg-5">
                  Can staff follow up?
                </div>

                <div class="chat-loop-message bot msg-6">
                  Yes. If the question is complex, the chatbot can pass it to human staff.
                </div>

                <div class="typing-indicator">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>

              <div class="live-chat-footer">
                <span>Ask about hours, pricing, bookings, or orders...</span>
                <i class="fa-solid fa-paper-plane"></i>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="value-strip">
        <div class="container value-grid">
          <div>Instant replies</div>
          <div>Less repeated manual work</div>
          <div>Better customer experience</div>
        </div>
      </section>

      <!-- Product explanation: 3-step visual flow -->
      <section id="product-flow" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="section-label">Product</p>
            <h2>How it fits together</h2>
          </div>
          <div class="card-grid three-up">
            <article class="feature-card">
              <div class="preview-label">1</div>
              <h3>Chat widget</h3>
              <p>Customers ask questions on your site.</p>
            </article>
            <article class="feature-card">
              <div class="preview-label">2</div>
              <h3>Plugin admin</h3>
              <p>Simple admin tools let you manage replies and handoffs.</p>
            </article>
            <article class="feature-card">
              <div class="preview-label">3</div>
              <h3>Content update</h3>
              <p>Answers stay current with minimal editing to your site content.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="problem" class="section">
        <div class="container section-grid">
          <div>
            <p class="section-label">Problem</p>
            <h2>Small businesses lose time answering the same questions.</h2>
            <p>Customers ask repeated questions about opening hours, prices, bookings, and orders. Business owners are
              busy serving customers, and slow replies can lead to missed sales.</p>
          </div>
          <div class="info-card">
            <div class="info-item"><i class="fa-solid fa-circle-check"></i> Repeated questions take time to answer</div>
            <div class="info-item"><i class="fa-solid fa-circle-check"></i> Owners are often busy serving customers
            </div>
            <div class="info-item"><i class="fa-solid fa-circle-check"></i> Slow replies can lead to missed sales</div>
            <div class="info-item"><i class="fa-solid fa-circle-check"></i> Manual replies create stress and effort
            </div>
          </div>
        </div>
      </section>

      <section id="solution" class="section alt-bg">
        <div class="container">
          <div class="section-heading">
            <p class="section-label">Solution</p>
            <h2>An AI assistant for everyday customer enquiries.</h2>
          </div>
          <div class="card-grid three-up">
            <article class="feature-card">
              <h3>Answer common FAQs</h3>
              <p>Respond instantly to frequent questions about services, hours, and policies.</p>
            </article>
            <article class="feature-card">
              <h3>Guide customers to action</h3>
              <p>Help customers move forward with bookings, orders, or next steps.</p>
            </article>
            <article class="feature-card">
              <h3>Escalate when needed</h3>
              <p>If the enquiry is complex, the chatbot can pass it to human staff.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="how-it-works" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="section-label">How it works</p>
            <h2>Simple steps, confident support.</h2>
          </div>
          <div class="steps-grid">
            <article class="step-card">
              <div class="step-number">01</div>
              <h3>Customer asks a question</h3>
              <p>A customer sends a common enquiry through the website or chat.</p>
            </article>
            <article class="step-card">
              <div class="step-number">02</div>
              <h3>The chatbot checks the enquiry type</h3>
              <p>It identifies the question and prepares a helpful response.</p>
            </article>
            <article class="step-card">
              <div class="step-number">03</div>
              <h3>Customer receives an instant reply</h3>
              <p>The customer gets a fast answer while your team stays focused.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="features" class="section alt-bg">
        <div class="container">
          <div class="section-heading">
            <p class="section-label">Features</p>
            <h2>Built for everyday business support.</h2>
          </div>
          <div class="card-grid four-up">
            <article class="feature-card">
              <h3>Opening hours replies</h3>
              <p>Give customers quick answers about availability.</p>
            </article>
            <article class="feature-card">
              <h3>Pricing and product info</h3>
              <p>Share key details without extra effort.</p>
            </article>
            <article class="feature-card">
              <h3>Booking enquiry support</h3>
              <p>Help customers start booking requests smoothly.</p>
            </article>
            <article class="feature-card">
              <h3>Order status support</h3>
              <p>Support simple order follow-up questions.</p>
            </article>
            <article class="feature-card">
              <h3>FAQ automation</h3>
              <p>Reduce repeated questions and save time.</p>
            </article>
            <article class="feature-card">
              <h3>Human staff escalation</h3>
              <p>Route complex cases to the right person.</p>
            </article>
            <article class="feature-card">
              <h3>Multi-channel support placeholder</h3>
              <p>Prepared for future website and messaging channels.</p>
            </article>
            <article class="feature-card">
              <h3>Chatbot embed placeholder</h3>
              <p>Ready for Botpress or n8n integration later.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="services" class="section services-section">
        <div class="container">
          <div class="section-heading">
            <p class="section-label">Services</p>
            <h2>Affordable chatbot flows for small businesses.</h2>
            <p class="services-subheading">Choose a simple chatbot flow based on what your business needs. Prices start
              from $5 to $10 for prototype/demo services.</p>
          </div>

          <div class="services-grid">
            <article class="service-card">
              <div class="service-top">
                <h3>Botpress Chatbot Flow</h3>
                <div class="service-price">$5</div>
              </div>
              <p>A simple Botpress chatbot flow for FAQs, opening hours, pricing, and booking enquiries.</p>
              <ul class="service-features">
                <li>Basic FAQ flow</li>
                <li>Customer enquiry replies</li>
                <li>Human handoff message</li>
              </ul>
              <a class="service-btn" href="/checkout?plan=Botpress%20Chatbot%20Flow&price=5">Request Botpress Flow</a>
            </article>

            <article class="service-card">
              <div class="service-top">
                <h3>Telegram Bot Flow</h3>
                <div class="service-price">$8</div>
              </div>
              <p>A Telegram bot flow for SMEs that want customer enquiries to come through Telegram.</p>
              <ul class="service-features">
                <li>Telegram bot conversation flow</li>
                <li>Basic automated replies</li>
                <li>Staff follow-up message</li>
              </ul>
              <a class="service-btn" href="/checkout?plan=Telegram%20Bot%20Flow&price=8">Request Telegram Bot</a>
            </article>

            <article class="service-card">
              <div class="service-top">
                <h3>Custom SME Flow</h3>
                <div class="service-price">$10</div>
              </div>
              <p>A slightly more customised chatbot flow based on the business type and service needs.</p>
              <ul class="service-features">
                <li>Custom FAQ categories</li>
                <li>Botpress or Telegram option</li>
                <li>Simple business-specific replies</li>
              </ul>
              <a class="service-btn" href="/checkout?plan=Custom%20SME%20Flow&price=10">Request Custom Flow</a>
            </article>
          </div>
        </div>
      </section>

      <!-- Split product demo: text left, mockup right -->
      <section class="section">
        <div class="container">
          <div class="split-demo">
            <div class="split-left">
              <p class="section-label">Demo</p>
              <h2>See the chatbot in context</h2>
              <p class="hero-text">The chat widget gives customers fast answers to hours, pricing, bookings and order
                questions — with easy escalation to your staff.</p>
              <a class="btn btn-secondary" href="/demo">Open full demo</a>
            </div>
            <div class="split-right hero-card">
              <div class="preview-card">
                <div class="preview-label">Mockup</div>
                <div class="bubble customer">Do you have today's menu?</div>
                <div class="bubble bot">Yes — today's specials are on the menu page. Want me to show it?</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section alt-bg demo-preview-section">
        <div class="container demo-preview-card">
          <div>
            <p class="section-label">Demo preview</p>
            <h2>See how the chatbot responds.</h2>
            <p>This demo uses simple sample replies. The real chatbot will be connected separately using Botpress or
              n8n.</p>
          </div>
          <a class="btn btn-primary" href="/demo">Open Demo</a>
        </div>
      </section>
      <section class="cta-section">
        <div class="container cta-card">
          <h2>Ready to reply faster?</h2>
          <p>Give your customers quick answers while reducing the workload on your team.</p>
          <a class="btn btn-primary" href="/demo">Try Demo</a>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
    <script src="/js/site-animations.js"></script>
</body>

</html>